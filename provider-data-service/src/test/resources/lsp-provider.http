### 1. Create a Legal Services Provider firm
# firmType and name are top-level fields in ProviderCreateV2.
# legalServicesProvider contains head office details — address, payment, and liaisonManager
# are required; the head office is created atomically with the provider.
POST http://localhost:8080/provider-firms
Content-Type: application/json

{
  "firmType": "Legal Services Provider",
  "name": "Westgate Legal Services LLP",
  "legalServicesProvider": {
    "constitutionalStatus": "Limited Liability Partnership (LLP)",
    "indemnityReceivedDate": "2024-04-01",
    "companiesHouseNumber": "OC123456",
    "address": {
      "line1": "Old County Court",
      "line2": "56 Westgate Road",
      "townOrCity": "Newcastle upon Tyne",
      "postcode": "NE1 1TT"
    },
    "telephoneNumber": "0191 498 0100",
    "emailAddress": "admin@westgatelegal.example",
    "website": "www.westgatelegal.example",
    "vatRegistration": {
      "vatNumber": "476628407"
    },
    "payment": {
      "paymentMethod": "EFT",
      "bankAccountDetails": {
        "accountName": "Westgate Legal LLP Client A/C",
        "sortCode": "601111",
        "accountNumber": "06805333"
      }
    },
    "dxDetails": {
      "dxNumber": "DX 61003",
      "dxCentre": "Newcastle upon Tyne"
    },
    "liaisonManager": {
      "firstName": "Alice",
      "lastName": "Patel",
      "emailAddress": "a.patel@westgatelegal.example",
      "telephoneNumber": "0191 498 0101",
      "activeDateFrom": "2024-04-01"
    }
  }
}

> {%
  client.global.set("providerFirmGUID", response.body.data.providerFirmGUID);
  client.global.set("providerFirmNumber", response.body.data.providerFirmNumber);
%}

### 2. Get the provider firm by GUID
GET http://localhost:8080/provider-firms/{{providerFirmGUID}}

### 3. Get the provider firm by firm number
GET http://localhost:8080/provider-firms/{{providerFirmNumber}}

### 4a. Create an office — link head office liaison manager, EFT payment (create new bank account)
# Uses a distinct account number from step 1 so bank-account filtering in steps 7b/8b is meaningful.
POST http://localhost:8080/provider-firms/{{providerFirmGUID}}/offices
Content-Type: application/json

{
  "address": {
    "line1": "Old County Court",
    "line2": "56 Westgate Road",
    "townOrCity": "Newcastle upon Tyne",
    "postcode": "NE1 1TT"
  },
  "telephoneNumber": "0191 498 0100",
  "emailAddress": "westgate@example.com",
  "website": "www.westgatelegal.example",
  "vatRegistration": {
    "vatNumber": "476628407"
  },
  "payment": {
    "paymentMethod": "EFT",
    "bankAccountDetails": {
      "accountName": "Westgate Legal LLP Office A/C",
      "sortCode": "601111",
      "accountNumber": "07916244"
    }
  },
  "dxDetails": {
    "dxNumber": "DX 61003",
    "dxCentre": "Newcastle upon Tyne"
  },
  "liaisonManager": {
    "useHeadOfficeLiaisonManager": true
  }
}

> {%
  client.global.set("officeGUID", response.body.data.officeGUID);
  client.global.set("officeCode", response.body.data.officeCode);
%}

### 4b. Create an office — new liaison manager, cheque payment
POST http://localhost:8080/provider-firms/{{providerFirmGUID}}/offices
Content-Type: application/json

{
  "address": {
    "line1": "14 King Street",
    "line2": "City Centre",
    "townOrCity": "Manchester",
    "postcode": "M2 6AZ"
  },
  "telephoneNumber": "0161 496 0100",
  "emailAddress": "manchester@example.com",
  "payment": {
    "paymentMethod": "CHECK"
  },
  "liaisonManager": {
    "firstName": "Jane",
    "lastName": "Smith",
    "emailAddress": "jane.smith@example.com",
    "telephoneNumber": "07700 900123",
    "activeDateFrom": "2024-04-01"
  }
}

> {%
  client.global.set("officeCheckGUID", response.body.data.officeGUID);
%}

### 5a. List offices for the provider
GET http://localhost:8080/provider-firms/{{providerFirmGUID}}/offices

### 5b. List offices — paginated
GET http://localhost:8080/provider-firms/{{providerFirmGUID}}/offices?page=0&pageSize=10

### 6a. Get a single office by GUID
GET http://localhost:8080/provider-firms/{{providerFirmGUID}}/offices/{{officeGUID}}

### 6b. Get a single office by account number
GET http://localhost:8080/provider-firms/{{providerFirmGUID}}/offices/{{officeCode}}

### 7a. List all bank accounts for the provider firm
# After steps 1 and 4a, two bank accounts exist: one from the head office (06805333),
# one from step 4a (07916244).
GET http://localhost:8080/provider-firms/{{providerFirmGUID}}/bank-details

> {%
  client.global.set("bankAccountGUID", response.body.data.content[0].guid);
%}

### 7b. List bank accounts — filtered by partial account number (matches only the head office account)
GET http://localhost:8080/provider-firms/{{providerFirmGUID}}/bank-details?bankAccountNumber=0680

### 7c. List bank accounts — paginated
GET http://localhost:8080/provider-firms/{{providerFirmGUID}}/bank-details?page=0&pageSize=1

### 8a. List bank accounts for the EFT office (step 4a) — expects one account
GET http://localhost:8080/provider-firms/{{providerFirmGUID}}/offices/{{officeGUID}}/bank-details

### 8b. List bank accounts — filtered (matches the office account number)
GET http://localhost:8080/provider-firms/{{providerFirmGUID}}/offices/{{officeGUID}}/bank-details?bankAccountNumber=0791

### 8c. List bank accounts for the cheque office (step 4b) — expects empty list
GET http://localhost:8080/provider-firms/{{providerFirmGUID}}/offices/{{officeCheckGUID}}/bank-details

### 9. Create an office — link an existing bank account by GUID (requires bankAccountGUID from step 7a)
POST http://localhost:8080/provider-firms/{{providerFirmGUID}}/offices
Content-Type: application/json

{
  "address": {
    "line1": "5 Broad Street",
    "townOrCity": "Bristol",
    "postcode": "BS1 2EL"
  },
  "telephoneNumber": "0117 496 0100",
  "emailAddress": "bristol@example.com",
  "payment": {
    "paymentMethod": "EFT",
    "bankAccountDetails": {
      "type": "link",
      "bankAccountGUID": "{{bankAccountGUID}}"
    }
  },
  "liaisonManager": {
    "useHeadOfficeLiaisonManager": true
  }
}
