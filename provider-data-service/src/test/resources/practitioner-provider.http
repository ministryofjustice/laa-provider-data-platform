### 1. Create a parent Chambers firm
# The Chambers is the prerequisite for creating Advocates.
POST http://localhost:8080/provider-firms
Content-Type: application/json

{
  "firmType": "Chambers",
  "name": "Northgate Chambers",
  "chambers": {
    "address": {
      "line1": "2 Temple Row",
      "line2": "City Centre",
      "townOrCity": "Birmingham",
      "postcode": "B2 5LG"
    },
    "telephoneNumber": "0121 496 0100",
    "emailAddress": "clerks@northgatechambers.example",
    "liaisonManager": {
      "firstName": "Robert",
      "lastName": "Clarke",
      "emailAddress": "r.clarke@northgatechambers.example",
      "telephoneNumber": "0121 496 0101",
      "activeDateFrom": "2024-04-01"
    }
  }
}

> {%
  client.global.set("chambersFirmNumber", response.body.data.providerFirmNumber);
%}

### 2a. Create a Practitioner firm — Advocate
# An office link is created pointing to the parent Chambers' head office.
# EFT payment creates a bank account linked to that office.
POST http://localhost:8080/provider-firms
Content-Type: application/json

{
  "firmType": "Advocate",
  "name": "J. Smith Advocate",
  "practitioner": {
    "advocateType": "Advocate",
    "parentFirms": [
      { "parentFirmNumber": "{{chambersFirmNumber}}" }
    ],
    "advocate": {
      "advocateLevel": "Junior",
      "solicitorRegulationAuthorityRollNumber": "SRA123456"
    },
    "payment": {
      "paymentMethod": "EFT",
      "bankAccountDetails": {
        "accountName": "J Smith Client Account",
        "sortCode": "200000",
        "accountNumber": "55779911"
      }
    },
    "liaisonManager": {
      "useChambersLiaisonManager": true
    }
  }
}

> {%
  if (response.body.data) {
    client.global.set("advocateGUID", response.body.data.providerFirmGUID);
    client.global.set("advocateFirmNumber", response.body.data.providerFirmNumber);
  }
%}

### 2b. Create a Practitioner firm — Barrister
# Cheque payment — no bank account created.
POST http://localhost:8080/provider-firms
Content-Type: application/json

{
  "firmType": "Advocate",
  "name": "T. Jones Barrister",
  "practitioner": {
    "advocateType": "Barrister",
    "parentFirms": [
      { "parentFirmNumber": "{{chambersFirmNumber}}" }
    ],
    "barrister": {
      "barristerLevel": "KC",
      "barCouncilRollNumber": "BC78901"
    },
    "payment": {
      "paymentMethod": "CHECK"
    },
    "liaisonManager": {
      "useChambersLiaisonManager": true
    }
  }
}

### 3. Get the Advocate firm by GUID
GET http://localhost:8080/provider-firms/{{advocateGUID}}

### 4. Get the Advocate firm by firm number
GET http://localhost:8080/provider-firms/{{advocateFirmNumber}}

### 5. Get bank-details for the Advocate firm — returns only this Advocate's bank accounts
GET http://localhost:8080/provider-firms/{{advocateGUID}}/bank-details

### 6. List offices for the Advocate — returns the single Chambers office they are linked to
GET http://localhost:8080/provider-firms/{{advocateGUID}}/offices

> {%
  if (response.body.data) {
    client.global.set("advocateOfficeCode", response.body.data.content[0].accountNumber);
  }
%}

### 7. Get office-level bank-details for the Advocate — returns this Advocate's bank accounts
# Uses the office account number (accountNumber from step 6) as the office identifier.
GET http://localhost:8080/provider-firms/{{advocateGUID}}/offices/{{advocateOfficeCode}}/bank-details
