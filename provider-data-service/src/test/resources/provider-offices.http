### 1a. Create a Legal Services Provider firm
# firmType and name are top-level fields in ProviderCreateV2.
# legalServicesProvider contains head office details — address, payment, and liaisonManager
# are required; the head office is created atomically with the provider.
POST http://localhost:8080/provider-firms
Content-Type: application/json

{
  "firmType": "Legal Services Provider",
  "name": "Westgate Legal Services LLP",
  "legalServicesProvider": {
    "constitutionalStatus": "Limited Liability Partnership (LLP)",
    "indemnityReceivedDate": "2024-04-01",
    "companiesHouseNumber": "OC123456",
    "address": {
      "line1": "Old County Court",
      "line2": "56 Westgate Road",
      "townOrCity": "Newcastle upon Tyne",
      "postcode": "NE1 1TT"
    },
    "telephoneNumber": "0191 498 0100",
    "emailAddress": "admin@westgatelegal.example",
    "website": "www.westgatelegal.example",
    "vatRegistration": {
      "vatNumber": "476628407"
    },
    "payment": {
      "paymentMethod": "EFT",
      "bankAccountDetails": {
        "accountName": "Westgate Legal LLP Client A/C",
        "sortCode": "601111",
        "accountNumber": "06805333"
      }
    },
    "dxDetails": {
      "dxNumber": "DX 61003",
      "dxCentre": "Newcastle upon Tyne"
    },
    "liaisonManager": {
      "firstName": "Alice",
      "lastName": "Patel",
      "emailAddress": "a.patel@westgatelegal.example",
      "telephoneNumber": "0191 498 0101",
      "activeDateFrom": "2024-04-01"
    }
  }
}

> {%
  client.global.set("providerFirmGUID", response.body.data.providerFirmGUID);
%}

### 1b. Create a Chambers firm
# chambers contains head office details — address and liaisonManager are required.
# The head office is created atomically with the provider.
POST http://localhost:8080/provider-firms
Content-Type: application/json

{
  "firmType": "Chambers",
  "name": "Northgate Chambers",
  "chambers": {
    "address": {
      "line1": "2 Temple Row",
      "line2": "City Centre",
      "townOrCity": "Birmingham",
      "postcode": "B2 5LG"
    },
    "telephoneNumber": "0121 496 0100",
    "emailAddress": "clerks@northgatechambers.example",
    "website": "www.northgatechambers.example",
    "dxDetails": {
      "dxNumber": "DX 13009",
      "dxCentre": "Birmingham"
    },
    "liaisonManager": {
      "firstName": "Robert",
      "lastName": "Clarke",
      "emailAddress": "r.clarke@northgatechambers.example",
      "telephoneNumber": "0121 496 0101",
      "activeDateFrom": "2024-04-01"
    }
  }
}

### 1c. Create a Practitioner firm — Advocate
# Practitioners have no head office; only the provider record is created.
POST http://localhost:8080/provider-firms
Content-Type: application/json

{
  "firmType": "Advocate",
  "name": "J. Smith Advocate",
  "practitioner": {
    "advocateType": "Advocate",
    "parentFirms": [
      { "parentFirmNumber": "0B111C" }
    ],
    "advocate": {
      "advocateLevel": "Junior",
      "solicitorRegulationAuthorityRollNumber": "SRA123456"
    },
    "payment": {
      "paymentMethod": "EFT",
      "bankAccountDetails": {
        "accountName": "J Smith Client Account",
        "sortCode": "200000",
        "accountNumber": "55779911"
      }
    },
    "liaisonManager": {
      "useChambersLiaisonManager": true
    }
  }
}

### 1d. Create a Practitioner firm — Barrister
POST http://localhost:8080/provider-firms
Content-Type: application/json

{
  "firmType": "Advocate",
  "name": "T. Jones Barrister",
  "practitioner": {
    "advocateType": "Barrister",
    "parentFirms": [
      { "parentFirmNumber": "0B111C" }
    ],
    "barrister": {
      "barristerLevel": "KC",
      "barCouncilRollNumber": "BC78901"
    },
    "payment": {
      "paymentMethod": "CHECK"
    },
    "liaisonManager": {
      "firstName": "Tom",
      "lastName": "Jones",
      "emailAddress": "t.jones@example.com",
      "telephoneNumber": "07700 900456"
    }
  }
}

### 2a. Create an office — use head office liaison manager, EFT payment
POST http://localhost:8080/provider-firms/{{providerFirmGUID}}/offices
Content-Type: application/json

{
  "address": {
    "line1": "Old County Court",
    "line2": "56 Westgate Road",
    "townOrCity": "Newcastle upon Tyne",
    "postcode": "NE1 1TT"
  },
  "telephoneNumber": "0191 498 0100",
  "emailAddress": "westgate@example.com",
  "website": "www.westgatelegal.example",
  "vatRegistration": {
    "vatNumber": "476628407"
  },
  "payment": {
    "paymentMethod": "EFT",
    "bankAccountDetails": {
      "accountName": "Westgate Legal LLP Client A/C",
      "sortCode": "601111",
      "accountNumber": "06805333"
    }
  },
  "dxDetails": {
    "dxNumber": "DX 61003",
    "dxCentre": "Newcastle upon Tyne"
  },
  "liaisonManager": {
    "useHeadOfficeLiaisonManager": true
  }
}

> {%
  client.global.set("officeGUID", response.body.data.officeGUID);
  client.global.set("officeCode", response.body.data.officeCode);
%}

### 2b. Create an office — new liaison manager, cheque payment
POST http://localhost:8080/provider-firms/{{providerFirmGUID}}/offices
Content-Type: application/json

{
  "address": {
    "line1": "14 King Street",
    "line2": "City Centre",
    "townOrCity": "Manchester",
    "postcode": "M2 6AZ"
  },
  "telephoneNumber": "0161 496 0100",
  "emailAddress": "manchester@example.com",
  "payment": {
    "paymentMethod": "CHECK"
  },
  "liaisonManager": {
    "firstName": "Jane",
    "lastName": "Smith",
    "emailAddress": "jane.smith@example.com",
    "telephoneNumber": "07700 900123",
    "activeDateFrom": "2024-04-01"
  }
}

### 3a. List offices for a provider
GET http://localhost:8080/provider-firms/{{providerFirmGUID}}/offices

### 3b. List offices — paginated
GET http://localhost:8080/provider-firms/{{providerFirmGUID}}/offices?page=0&pageSize=10

### 4a. Get a single office by GUID
GET http://localhost:8080/provider-firms/{{providerFirmGUID}}/offices/{{officeGUID}}

### 4b. Get a single office by account number
GET http://localhost:8080/provider-firms/{{providerFirmGUID}}/offices/{{officeCode}}

### 5. Get a provider firm by GUID
GET http://localhost:8080/provider-firms/{{providerFirmGUID}}

### 5b. Get a provider firm by firm number
GET http://localhost:8080/provider-firms/LSP-ABCD1234

